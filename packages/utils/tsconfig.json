{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "module": "nodenext",
    "allowJs": false,
    "declaration": false,
    "removeComments": true,
    "isolatedModules": true,
    "strict": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "moduleResolution": "nodenext",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap" : true,
    "rootDir": "./src",
    "outDir": "./dist"
  },
  "include": ["./src"]
}
