{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Medley",
  "description": "Configuration file for Medley",
  "type": "object",
  "properties": {
    "server": {
      "title": "Server",
      "description": "Web server configuration",
      "type": "object",
      "properties": {
        "port": {
          "title": "Port",
          "description": "HTTP server port number",
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "address": {
          "title": "Address",
          "description": "IP address to bind the server to",
          "$ref": "#/$defs/ipAddress"
        },
        "audioBitrate": {
          "title": "Audio Bitrate",
          "description": "Bitrate for Opus audio, in kbps",
          "type": "integer",
          "minimum": 0,
          "maximum": 256
        },
        "secret": {
          "title": "Secret",
          "type": "string",
          "description": "Secret used to sign sessions",
          "minLength": 16
        }
      },
      "required": [],
      "additionalProperties": false
    },
    "webrtc": {
      "title": "WebRTC",
      "description": "WebRTC server configuration",
      "properties": {
        "listens": {
          "title": "Listen Addresses",
          "description": "List of network interfaces and ports to listen on",
          "type": "array",
          "items": {
            "type": "object",
            "title": "Listen",
            "properties": {
              "protocol": {
                "title": "Network Protocol",
                "description": "Transport protocol to use",
                "oneOf": [
                  {
                    "type": "string",
                    "const": "tcp"
                  },
                  {
                    "type": "string",
                    "const": "udp"
                  }
                ]
              },
              "ip": {
                "title": "Listening IP",
                "description": "IP address to listen on",
                "anyOf": [
                  {
                    "const": "0.0.0.0",
                    "markdownDescription": "`announcedIp` must also be set when the `ip` is set to `0.0.0.0`"
                  },
                  {
                    "const": "::",
                    "markdownDescription": "`announcedIp` must also be set when the `ip` is set to `::`"
                  },
                  { "$ref": "#/$defs/ipAddress" }
                ]
              },
              "port": {
                "title": "Port",
                "description": "Port number to listen on",
                "type": "integer",
                "minimum": 1,
                "maximum": 65535
              },
              "announcedIp": {
                "title": "Announced IP",
                "description": "Required when running behind NAT with a private IP",
                "$ref": "#/$defs/ipAddress"
              }
            },
            "required": ["protocol", "ip"],
            "allOf": [
              {
                "if": {
                  "properties": {
                    "ip": {
                      "oneOf": [
                        {
                          "const": "0.0.0.0"
                        },
                        {
                          "const": "::"
                        }
                      ]
                    }
                  }
                },
                "then": {
                  "required": ["protocol", "ip", "announcedIp"]
                }
              }
            ],
            "additionalProperties": false
          }
        },
        "bitrate": {
          "title": "Bitrate",
          "description": "Bitrate for Opus audio, in kbps",
          "type": "integer",
          "minimum": 0,
          "maximum": 256
        }
      },
      "required": ["listens"],
      "additionalProperties": false
    },
    "db": {
      "$ref": "#/$defs/db"
    },
    "stations": {
      "title": "Stations",
      "description": "Map of stations",
      "type": "object",
      "patternProperties": {
        "^.+$": {
          "$ref": "#/$defs/station"
        }
      }
    },
    "automatons": {
      "title": "Automatons",
      "description": "Map of Discord bots",
      "type": "object",
      "patternProperties": {
        "^.+$": {
          "$ref": "#/$defs/automaton"
        }
      }
    },
    "streaming": {
      "title": "Streaming Outputs",
      "description": "List of streaming outputs",
      "type": "array",
      "items": {
        "$ref": "#/$defs/streaming_output"
      }
    }
  },
  "required": ["db", "stations"],
  "additionalProperties": false,
  "$defs": {
    "db": {
      "title": "Database",
      "oneOf": [
        {
          "type": "object",
          "title": "MongoDB",
          "description": "MongoDB connection options",
          "properties": {
            "driver": {
              "const": "mongodb"
            },
            "url": {
              "title": "URL",
              "description": "MongoDB connection string",
              "type": "string",
              "minLength": 1
            },
            "database": {
              "title": "Database",
              "description": "Database name",
              "type": "string",
              "minLength": 1
            },
            "connectionOptions": {
              "title": "Connection Options",
              "type": "object",
              "markdownDescription": "See: [Driver Documentation](https://www.mongodb.com/docs/manual/reference/connection-string)"
            },
            "metadataTTL": {
              "markdownDescription": "**Deprecated:** No longer used\n\nTime-To-Live for music metadata",
              "type": "object",
              "properties": {
                "min": {
                  "type": "integer",
                  "minimum": 0
                },
                "max": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            }
          },
          "required": ["driver", "url", "database"],
          "additionalProperties": false
        }
      ]
    },
    "station": {
      "title": "Station",
      "description": "Station configuration",
      "type": "object",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string",
          "description": "Station name",
          "minLength": 1
        },
        "description": {
          "title": "Description",
          "type": "string",
          "description": "Station description"
        },
        "url": {
          "title": "URL",
          "type": "string",
          "description": "Station URL"
        },
        "iconURL": {
          "title": "Icon URL",
          "type": "string",
          "description": "URL of the station icon"
        },
        "maxTrackHistory": {
          "title": "Max Track History",
          "type": "integer",
          "description": "Number of tracks to keep in history",
          "minimum": 0,
          "default": 20
        },
        "artistBacklog": {
          "title": "Artist Backlog",
          "oneOf": [
            {
              "type": "boolean",
              "const": false,
              "description": "Disable artist duplication check"
            },
            {
              "type": "integer",
              "minimum": 0,
              "default": 50,
              "description": "Number of recent tracks to check for duplicate artists"
            }
          ]
        },
        "duplicationSimilarity": {
          "title": "Duplication Similarity",
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Similarity threshold from 0 to 1 for detecting duplicate artists"
        },
        "musicCollections": {
          "title": "Music Collections",
          "type": "object",
          "description": "Map of music collections",
          "patternProperties": {
            "^.+$": {
              "$ref": "#/$defs/musicCollection"
            }
          }
        },
        "profiles": {
          "title": "Station Profiles",
          "type": "object",
          "description": "Map of station profiles; at least the default profile must be defined",
          "patternProperties": {
            "^.+$": {
              "$ref": "#/$defs/stationProfile"
            }
          },
          "required": ["default"]
        }
      },
      "required": ["name", "description", "musicCollections", "profiles"],
      "additionalProperties": false
    },
    "automaton": {
      "title": "Automaton",
      "description": "Discord bot configuration",
      "type": "object",
      "properties": {
        "clientId": {
          "title": "Client ID",
          "description": "Discord application client ID",
          "type": "string",
          "minLength": 1
        },
        "botToken": {
          "title": "Bot Token",
          "description": "Discord bot token",
          "type": "string",
          "minLength": 1
        },
        "owners": {
          "type": "array",
          "title": "Owners",
          "description": "List of bot owner IDs",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "stations": {
          "title": "Stations",
          "type": "array",
          "description": "List of station IDs allowed to be tuned from this bot; leave empty to allow all stations",
          "items": {
            "type": "string"
          }
        },
        "baseCommand": {
          "title": "Base Command",
          "type": "string",
          "description": "Base slash command name",
          "minLength": 1,
          "default": "medley"
        },
        "guilds": {
          "title": "Guilds",
          "type": "object",
          "description": "Guild-specific configurations",
          "patternProperties": {
            "^.+$": {
              "$ref": "#/$defs/guildConfig"
            }
          }
        }
      },
      "required": ["clientId", "botToken"],
      "additionalProperties": false
    },
    "musicCollection": {
      "title": "Music Collection",
      "type": "object",
      "properties": {
        "paths": {
          "title": "Paths",
          "description": "List of directories to scan for music files",
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/dirPath"
          }
        },
        "description": {
          "title": "Description",
          "description": "Collection description",
          "type": "string"
        },
        "auxiliary": {
          "title": "Auxiliary",
          "type": "boolean",
          "description": "Mark this collection as auxiliary; an auxiliary collection cannot be used in a playing sequence"
        },
        "noFollowOnRequest": {
          "title": "No Follow On Request",
          "type": "boolean",
          "description": "Disable crate following on a requested track",
          "default": false
        },
        "disableLatch": {
          "title": "Disable Latch",
          "type": "boolean",
          "description": "Disable latching",
          "default": false
        },
        "newTracksAddingMode": {
          "title": "New Tracks Adding Mode",
          "type": "string",
          "description": "How new tracks are added to the collection",
          "enum": ["prepend", "append", "spread"],
          "default": "spread"
        },
        "reshuffleEvery": {
          "title": "Reshuffle Every",
          "type": "integer",
          "description": "Number of tracks played from this collection before re-shuffling",
          "minimum": 0
        }
      },
      "required": ["paths", "description"],
      "additionalProperties": false
    },
    "sequence": {
      "title": "Play Sequence",
      "type": "object",
      "properties": {
        "collections": {
          "title": "Collections",
          "type": "array",
          "description": "List of collection IDs and weights",
          "items": {
            "title": "Sequence Collection",
            "type": "object",
            "properties": {
              "id": {
                "title": "ID",
                "description": "Collection ID",
                "type": "string",
                "minLength": 1
              },
              "weight": {
                "title": "Weight",
                "description": "Relative weight for random selection",
                "type": "number"
              }
            },
            "required": ["id"],
            "additionalProperties": false
          }
        },
        "chance": {
          "title": "Chance",
          "description": "Probability of this sequence being selected",
          "oneOf": [
            {
              "type": "string",
              "const": "random"
            },
            {
              "type": "object",
              "title": "Yes/No Chance",
              "properties": {
                "yes": {
                  "title": "Yes",
                  "type": "integer",
                  "minimum": 0,
                  "description": "Weight for being selected"
                },
                "no": {
                  "title": "No",
                  "type": "integer",
                  "minimum": 0,
                  "description": "Weight for not being selected"
                }
              },
              "required": ["yes", "no"],
              "additionalProperties": false
            }
          ]
        },
        "limit": {
          "title": "Limit",
          "description": "Number of tracks to play after being selected",
          "oneOf": [
            {
              "type": "integer",
              "minimum": 0
            },
            {
              "type": "string",
              "description": "Play the entire collection before switching to the next",
              "const": "entirely"
            },
            {
              "type": "object",
              "title": "Up To Limit",
              "description": "Play up to a fixed number of tracks",
              "properties": {
                "by": {
                  "type": "string",
                  "const": "upto"
                },
                "upto": {
                  "title": "Up To",
                  "description": "Maximum number of tracks to play",
                  "type": "integer",
                  "minimum": 0
                }
              },
              "required": ["by", "upto"],
              "additionalProperties": false
            },
            {
              "type": "object",
              "title": "Range Limit",
              "description": "Play a random number of tracks within a range",
              "properties": {
                "by": {
                  "type": "string",
                  "const": "range"
                },
                "range": {
                  "title": "Range",
                  "type": "object",
                  "properties": {
                    "min": {
                      "title": "Min",
                      "description": "Minimum number of tracks",
                      "type": "integer",
                      "minimum": 0
                    },
                    "max": {
                      "title": "Max",
                      "description": "Maximum number of tracks",
                      "type": "integer",
                      "minimum": 0
                    }
                  },
                  "required": ["min", "max"],
                  "additionalProperties": false
                }
              },
              "required": ["by", "range"],
              "additionalProperties": false
            },
            {
              "type": "object",
              "title": "Sample Limit",
              "description": "Play a count randomly picked from a list",
              "properties": {
                "by": {
                  "type": "string",
                  "enum": ["sample", "one-of"]
                },
                "list": {
                  "title": "List",
                  "description": "List of track counts; one value is picked randomly",
                  "type": "array",
                  "items": {
                    "type": "integer",
                    "minimum": 0
                  }
                }
              },
              "required": ["by", "list"],
              "additionalProperties": false
            }
          ]
        }
      },
      "required": ["collections", "limit"],
      "additionalProperties": false
    },
    "stationProfile": {
      "title": "Station Profile",
      "type": "object",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string",
          "description": "Profile name",
          "minLength": 1
        },
        "description": {
          "title": "Description",
          "type": "string",
          "description": "Profile description"
        },
        "intros": {
          "title": "Intros",
          "description": "List of directories to pick an intro file from when starting this profile",
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "sweeperRules": {
          "title": "Sweeper Rules",
          "description": "List of rules for inserting a jingle track when transitioning between music collections",
          "type": "array",
          "items": {
            "$ref": "#/$defs/sweeperRule"
          }
        },
        "requestSweepers": {
          "title": "Request Sweepers",
          "type": "array",
          "description": "List of directories to pick a sweeper file from when transitioning into a new request session",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "followCollectionAfterRequestTrack": {
          "title": "Follow Collection After Request Track",
          "type": "boolean",
          "description": "Whether to follow the collection after playing a requested track",
          "default": true
        },
        "noRequestSweeperOnIdenticalCollection": {
          "title": "No Request Sweeper On Identical Collection",
          "type": "boolean",
          "description": "Skip inserting a request sweeper when consecutive tracks are from the same collection",
          "default": true
        },
        "sequences": {
          "title": "Sequences",
          "description": "List of play sequences defining how music tracks are selected",
          "type": "array",
          "items": {
            "$ref": "#/$defs/sequence"
          }
        }
      },
      "required": ["name", "sequences"]
    },
    "sweeperRule": {
      "title": "Sweeper Rule",
      "oneOf": [
        {
          "properties": {
            "from": {
              "$ref": "#/$defs/sweeperRuleFrom"
            },
            "path": {
              "$ref": "#/$defs/dirPath"
            }
          },
          "required": ["from", "path"],
          "not": {"required": ["to"]},
          "additionalProperties": false
        },
        {
          "properties": {
            "to": {
              "$ref": "#/$defs/sweeperRuleTo"
            },
            "path": {
              "$ref": "#/$defs/dirPath"
            }
          },
          "required": ["to", "path"],
          "not": {"required": ["from"]},
          "additionalProperties": false
        },
        {
          "properties": {
            "from": {
              "$ref": "#/$defs/sweeperRuleFrom"
            },
            "to": {
              "$ref": "#/$defs/sweeperRuleTo"
            },
            "path": {
              "$ref": "#/$defs/dirPath"
            }
          },
          "required": ["from", "to", "path"],
          "additionalProperties": false
        }
      ]
    },
    "sweeperRuleFrom": {
      "title": "From Collections",
      "description": "List of collection IDs that this sweeper should be inserted while transitioning from",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sweeperRuleTo": {
      "title": "To Collections",
      "description": "List of collection IDs that this sweeper should be inserted while transitioning to",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dirPath": {
      "title": "Directory Path",
      "type": "string",
      "description": "Path to a directory; recursively scanned and watched for music files",
      "minLength": 1
    },
    "guildConfig": {
      "title": "Guild Configuration",
      "type": "object",
      "description": "Guild-specific configuration",
      "properties": {
        "autotune": {
          "title": "Auto Tune",
          "type": "string",
          "description": "Station ID to tune into automatically on bot join",
          "minLength": 1
        },
        "autojoin": {
          "title": "Auto Join",
          "type": "string",
          "description": "Voice channel ID to join automatically",
          "minLength": 1
        },
        "trackMessage": {
          "title": "Track Message",
          "description": "Configuration for track announcement messages",
          "type": "object",
          "properties": {
            "type": {
              "title": "Type",
              "description": "Track message display style",
              "default": "extended",
              "oneOf": [
                {
                  "type": "string",
                  "const": "normal"
                },
                {
                  "type": "string",
                  "const": "extended"
                },
                {
                  "type": "string",
                  "const": "simple"
                }
              ]
            },
            "max": {
              "title": "Max",
              "type": "integer",
              "description": "Number of recent track messages to keep in the channel",
              "minimum": 0
            },
            "channel": {
              "title": "Channel",
              "type": "string",
              "description": "Text channel ID for sending track messages",
              "minLength": 1
            },
            "retainOnReaction": {
              "title": "Retain On Reaction",
              "type": "boolean",
              "description": "Keep the message if a reaction has been added to it"
            },
            "always": {
              "title": "Always",
              "type": "boolean",
              "description": "Always send track messages even when there are no listeners"
            }
          },
          "additionalProperties": false
        },
        "bitrate": {
          "title": "Bitrate",
          "description": "Bitrate for Opus audio, in kbps",
          "type": "integer",
          "minimum": 0,
          "maximum": 256,
          "default": 256
        },
        "gain": {
          "title": "Gain",
          "markdownDescription": "Audio gain level\n- 0 → 0%\n- 0.5 → 50%\n- 1.0 → 100%",
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 1.0
        },
        "djRoles": {
          "title": "DJ Roles",
          "description": "List of role IDs with DJ permissions",
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "ipAddress": {
      "oneOf": [
        {
          "type": "string",
          "description": "IPv4",
          "pattern": "^(25[0-5]|2[0-4][0-9]|1?[0-9][0-9]{1,2})(\\.(25[0-5]|2[0-4][0-9]|1?[0-9]{1,2})){3}$"
        },
        {
          "type": "string",
          "description": "IPv6",
          "pattern": "(([0-9a-fA-F]{1,4}:){7,7}[0-9a-fA-F]{1,4}|([0-9a-fA-F]{1,4}:){1,7}:|([0-9a-fA-F]{1,4}:){1,6}:[0-9a-fA-F]{1,4}|([0-9a-fA-F]{1,4}:){1,5}(:[0-9a-fA-F]{1,4}){1,2}|([0-9a-fA-F]{1,4}:){1,4}(:[0-9a-fA-F]{1,4}){1,3}|([0-9a-fA-F]{1,4}:){1,3}(:[0-9a-fA-F]{1,4}){1,4}|([0-9a-fA-F]{1,4}:){1,2}(:[0-9a-fA-F]{1,4}){1,5}|[0-9a-fA-F]{1,4}:((:[0-9a-fA-F]{1,4}){1,6})|:((:[0-9a-fA-F]{1,4}){1,7}|:)|fe80:(:[0-9a-fA-F]{0,4}){0,4}%[0-9a-zA-Z]{1,}|::(ffff(:0{1,4}){0,1}:){0,1}((25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9])\\.){3,3}(25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9])|([0-9a-fA-F]{1,4}:){1,4}:((25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9])\\.){3,3}(25[0-5]|(2[0-4]|1{0,1}[0-9]){0,1}[0-9]))"
        }
      ]
    },
    "streaming_output": {
      "title": "Streaming Output",
      "oneOf": [
        { "$ref": "#/$defs/shout_output" },
        { "$ref": "#/$defs/icy_output" },
        { "$ref": "#/$defs/udp_output"}
      ]
    },
    "shout_output": {
      "title": "Shout Output",
      "description": "Streaming output to an Icecast server via libshout",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "shout"
        },
        "station": {
          "title": "Station",
          "description": "Station ID to stream from",
          "type": "string",
          "minLength": 1
        },
        "icecast": {
          "type": "object",
          "title": "Icecast",
          "description": "Icecast server connection details",
          "properties": {
            "host": {
              "title": "Host",
              "description": "Icecast server hostname or IP address",
              "type": "string",
              "minLength": 1
            },
            "port": {
              "title": "Port",
              "description": "Icecast server port number",
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            "tls": {
              "title": "TLS",
              "description": "Enable TLS for the connection",
              "type": "boolean"
            },
            "mountpoint": {
              "title": "Mountpoint",
              "description": "Stream mountpoint path",
              "type": "string",
              "pattern": "^/[^/\\s]+$"
            },
            "username": {
              "title": "Username",
              "description": "Icecast source username",
              "type": "string",
              "minLength": 1
            },
            "password": {
              "title": "Password",
              "description": "Icecast source password",
              "type": "string",
              "minLength": 1
            },
            "public": {
              "title": "Public",
              "description": "Advertise this stream on the Icecast directory",
              "type": "boolean"
            }
          },
          "required": ["host", "port", "mountpoint", "username", "password"],
          "additionalProperties": false
        },
        "format": {
          "title": "Format",
          "description": "Audio encoding format",
          "type": "object",
          "required": ["codec"],
          "oneOf": [
            {
              "title": "FLAC",
              "type": "object",
              "properties": {
                "codec": {
                  "const": "flac"
                },
                "sampleRate": {
                  "type": "integer",
                  "title": "Sample Rate",
                  "description": "Sample rate in Hz",
                  "minimum": 8000,
