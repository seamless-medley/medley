{
  "name": "medley",
  "version": "0.1.0",
  "description": "Monorepo for Medley, audio engine for Node.js",
  "author": {
    "name": "Wittawas Nakkasem",
    "email": "vittee@hotmail.com"
  },
  "license": "GPL-3.0",
  "scripts": {
    "clean": "turbo run clean",
    "build": "turbo run build",
    "package": "turbo run package --filter=@seamless-medley/radio",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@types/node": "^24.1.0",
    "husky": "^9.1.7",
    "turbo": "^2.10.0",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@11.9.0",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.18.0",
      "onFail": "download"
    }
  }
}
